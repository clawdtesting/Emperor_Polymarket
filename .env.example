# ============================================================
# SOL Accumulation Grid Bot - environment configuration
# Copy to .env and fill in. NEVER commit your real .env.
# ============================================================

# --- Trading mode safety gate -------------------------------
# Real orders are ONLY placed when this is exactly "true".
LIVE_TRADING=false

# Run mode: paper | live | backtest  (CLI flag overrides this)
RUN_MODE=paper

# --- Exchange (Hyperliquid via CCXT) ------------------------
# Hyperliquid authenticates with a wallet address + an API/agent
# private key (NOT a classic key/secret pair).
# Create an "API wallet" (agent) at https://app.hyperliquid.xyz/API
# Give it trading permission only. NO withdrawal/transfer rights.
EXCHANGE=hyperliquid
HYPERLIQUID_WALLET_ADDRESS=
HYPERLIQUID_PRIVATE_KEY=
# Use the testnet endpoint while validating.
HYPERLIQUID_TESTNET=true

# --- Telegram alerts (optional) -----------------------------
# Leave blank to disable. If both are set, alerts are enabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Path to the YAML strategy config -----------------------
CONFIG_FILE=config/config.yaml

# --- Database -----------------------------------------------
DB_PATH=data/bot_state.sqlite3

# --- Kill switch: if this file exists, the bot stops ---------
KILL_SWITCH_FILE=KILL_SWITCH
